# Farcaster & Neynar Configuration
# Required for user registration and board creation APIs

# Neynar API Key (get from https://developer.neynar.com/)
NEXT_PUBLIC_NEYNAR_API_KEY=your_neynar_api_key_here

# Optional: for additional Neynar features
NEYNAR_API_KEY=your_neynar_api_key_here

# App Domain for JWT verification (used in API authentication)
# For production: moodboard-generator-phi.vercel.app (NO protocol)
# For local development: localhost:3000
APP_DOMAIN=moodboard-generator-phi.vercel.app
NEXT_PUBLIC_APP_DOMAIN=moodboard-generator-phi.vercel.app

# Database Configuration (Turso/LibSQL)
# Get from https://turso.tech/ or use your own database URL
TURSO_DATABASE_URL=your_turso_database_url_here
TURSO_AUTH_TOKEN=your_turso_auth_token_here

# Alternative: Direct database URL
# DATABASE_URL=your_database_url_here
