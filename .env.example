# Farcaster & Neynar Configuration
# Required for user registration and board creation APIs

# Neynar API Key (get from https://developer.neynar.com/)
NEXT_PUBLIC_NEYNAR_API_KEY=your_neynar_api_key_here

# Optional: for additional Neynar features
NEYNAR_API_KEY=your_neynar_api_key_here

# App Domain for JWT verification (used in API authentication)
# For production: https://moodboard-generator-phi.vercel.app
# For local development: http://localhost:3000
APP_DOMAIN=https://moodboard-generator-phi.vercel.app
NEXT_PUBLIC_APP_DOMAIN=https://moodboard-generator-phi.vercel.app

# Database URL (if using Turso or similar)
# DATABASE_URL=your_database_url_here
# TURSO_DATABASE_URL=your_database_url_here
# TURSO_AUTH_TOKEN=your_auth_token_here
